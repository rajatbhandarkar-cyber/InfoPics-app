<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Create a new Post</h3>
    <form method="POST" action="/posts" novalidate class="needs-validation" enctype="multipart/form-data">
      
      <!-- Image Upload -->
      <div class="mb-3">
        <label for="image" class="form-label">Upload Post Image</label>
        <input 
          name="post[image]" 
          type="file"
          class="form-control"
          required
        />
        <div class="valid-feedback">Picture looks good!</div>
      </div>

      <!-- Location -->
      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input 
          name="post[location]" 
          placeholder="Jaipur, Rajasthan" 
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please enter the location name!</div>
      </div>

      <!-- Country -->
      <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <input 
          name="post[country]" 
          placeholder="India"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please enter the country name!</div>
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label for="description" class="form-label">Experience / Story</label>
        <textarea 
          name="post[description]" 
          placeholder="Document your thoughts" 
          class="form-control large-textarea"
          required
        ></textarea>
        <div class="invalid-feedback">Please share your Experience / Story!</div>
      </div>

      <!-- Categories -->
      <div class="mb-3">
        <label class="form-label">Category</label>
        <div class="d-flex flex-wrap gap-3">
          <div>
            <input type="checkbox" name="post[categories]" value="Adventure" id="cat-adventure">
            <label for="cat-adventure">Adventure</label>
          </div>
          <div>
            <input type="checkbox" name="post[categories]" value="Forts" id="cat-forts">
            <label for="cat-forts">Forts</label>
          </div>
          <div>
            <input type="checkbox" name="post[categories]" value="Beaches" id="cat-beaches">
            <label for="cat-beaches">Beaches</label>
          </div>
          <div>
            <input type="checkbox" name="post[categories]" value="Temples" id="cat-temples">
            <label for="cat-temples">Temples</label>
          </div>
          <div>
            <input type="checkbox" name="post[categories]" value="Mountains" id="cat-mountains">
            <label for="cat-mountains">Mountains</label>
          </div>
          <div>
            <input type="checkbox" name="post[categories]" value="Culture" id="cat-culture">
            <label for="cat-culture">Culture</label>
          </div>
          <div>
            <input type="checkbox" name="post[categories]" value="Food" id="cat-food">
            <label for="cat-food">Food</label>
          </div>
          <div>
            <input type="checkbox" name="post[categories]" value="Hidden Gems" id="cat-hidden">
            <label for="cat-hidden">Hidden Gems</label>
          </div>
        </div>
        <small class="text-muted">Select one or more categories that best describe your post.</small>
      </div>

      <!-- Privacy toggle -->
      <div class="mb-3">
         <div class="privacy-container">
           <label class="form-label mb-0">Privacy</label>
           <label class="privacy-toggle">
             <input type="checkbox" name="post[isPrivate]" value="true" />
             <span class="privacy-slider"></span>
           </label>
         </div>
         <small class="text-muted d-block mt-1">
            By default, your post is public. Toggle to make it private.
         </small>
      </div>

      <!-- Submit -->
      <button class="btn btn-dark">Add</button>
      <br/><br/>
    </form>
  </div>
</div>
